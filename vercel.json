{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/index.html",
      "destination": "/api/index"
    },
    {
      "source": "/data",
      "destination": "/api/data"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 10
    },
    "api/data.py": {
      "maxDuration": 60
    }
  }
}
